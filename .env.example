# ============================================================================
# Rhythmscape — .env.example
# ============================================================================
# Copy this file to .env and fill in each key locally.
# .env is git-ignored.
#
# Issuance:
#   ANTHROPIC_API_KEY → https://console.anthropic.com/settings/keys
#   KOSIS_API_KEY     → https://kosis.kr/openapi/
#   SGIS_SERVICE_ID / SGIS_SECRET_KEY → https://sgis.kostat.go.kr/developer/
#   TAGO_API_KEY      → https://www.data.go.kr/data/15098534/openapi.do
#   VWORLD_API_KEY    → https://www.vworld.kr/dev/v4dv_apireference_s002.do
#   BIGKINDS_API_KEY  → https://www.bigkinds.or.kr/  (optional)
# ============================================================================

# --- Anthropic (Claude API) ---
ANTHROPIC_API_KEY=

# --- KOSIS (Korean Statistical Information Service) ---
KOSIS_API_KEY=

# --- SGIS (Statistical Geographic Information Service) ---
# Authentication: SERVICE_ID + SECRET_KEY → 2-step accessToken (TTL 4h)
SGIS_SERVICE_ID=
SGIS_SECRET_KEY=

# --- TAGO (National Traffic Information Center, data.go.kr) ---
TAGO_API_KEY=

# --- VWorld (National Spatial Information Platform) ---
VWORLD_API_KEY=

# --- BIGKinds (optional: enabled only for Changwon flagship discourse layer) ---
BIGKINDS_API_KEY=

# --- Paths ---
DATA_DIR=./data
OUTPUTS_DIR=./outputs
OSM_PBF_PATH=./data/osm/south-korea-latest.osm.pbf

# --- Runtime ---
LOG_LEVEL=INFO
DEFAULT_GRID_SIZE_M=500
DEFAULT_LANGS=ko,en

# --- Claude API strategy ---
USE_BATCH_API=true
USE_PROMPT_CACHING=true
ANTHROPIC_MODEL=claude-opus-4-7
